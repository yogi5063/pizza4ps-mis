# ─── Copy this file to ".env" on the server and fill in real values ───
# On the server run:   cp .env.example .env   then edit it:  nano .env

# Security — generate a long random string for SECRET_KEY (see deploy guide)
SECRET_KEY=CHANGE_ME_to_a_long_random_string

# Login for the dashboard's built-in admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_to_a_strong_password

# Token settings (defaults are fine)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
